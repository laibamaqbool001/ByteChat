# Forensics
EVIDENCE_EXPORT_SECRET=
HMAC_SECRET=
CHAIN_OF_CUSTODY_SECRET=

AES_ENCRYPTION_KEY=
AES_KEY_VERSION=1
# AES_ENCRYPTION_KEY_OLD=   # Only set during key rotation window

HMAC_SECRET=
EVIDENCE_EXPORT_SECRET=

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
CLIENT_URL=http://localhost:

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

